# 1Panel / OpenResty 上的泛域名站点配置
# 在 1Panel 里随便建一个站点(域名填 cdn.your.com),然后把它的 conf 替换成这个。
# 关键点:
#   1. 泛域名证书(*.cdn.your.com),DNS-01 申请
#   2. server_name 用泛域名,真正的 token 由网关从 Host 里提
#   3. Docker layer 是大文件流,必须关 buffering、放开 body size

server {
    listen 443 ssl http2;
    server_name ~^[a-z0-9]+\.cdn\.your\.com$;

    ssl_certificate     /etc/letsencrypt/live/cdn.your.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cdn.your.com/privkey.pem;

    # docker pull 大 layer 关键设置
    client_max_body_size  0;
    proxy_buffering       off;
    proxy_request_buffering off;
    proxy_http_version    1.1;
    proxy_read_timeout    900s;
    proxy_send_timeout    900s;

    location / {
        proxy_set_header Host              $host;       # 关键:把 token.cdn.your.com 原样传给网关
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 网关跑在同机 7000 端口
        proxy_pass http://127.0.0.1:7000;
    }
}

server {
    listen 80;
    server_name ~^[a-z0-9]+\.cdn\.your\.com$;
    return 301 https://$host$request_uri;
}
